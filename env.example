# Copy this file to ".env" (the app reads .env, NOT .env.example).
# Generate a strong key with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=paste-a-long-random-value-here

# Whichever email you put here becomes an admin the moment it logs in.
ADMIN_EMAIL=you@example.com

# That's it for the core app. SpeakPort runs 100% offline for every feature
# except the optional AI Roleplay below — no AI keys required, no per-user
# cost. All practice content lives in content.py.

# ---- Email, for "forgot password" reset links (optional) ----
# Leave everything below unset and "forgot password" runs in DEMO MODE:
# instead of emailing a link, the reset link is handed straight back in the
# API response, so the flow still fully works — you just have to copy/paste
# the link yourself instead of it landing in an inbox.
#
# Any SMTP account works — a Gmail address with an "app password"
# (myaccount.google.com/apppasswords), Zoho, Outlook, or the SMTP relay of a
# free-tier transactional service (Resend, Mailgun, SendGrid).
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_FROM=you@gmail.com          (optional, defaults to SMTP_USERNAME)
#
# Set this to your real site URL in production so reset links point to the
# right place (locally it falls back to whatever origin the request came
# from, which is fine for testing):
#   PUBLIC_URL=https://speakport-h4k8.onrender.com

# ---- Sign in with Google (optional) ----
# Leave unset and the "Sign in with Google" button just doesn't appear —
# everyone uses email + password as usual.
#
# Unlike everything else in this file, this is NOT a secret — a Client ID
# is a public identifier (safe in frontend code, like a Stripe "publishable
# key"), so there's no password/API-secret step here at all. Get one free:
#   1. console.cloud.google.com/apis/credentials (create a project if needed)
#   2. If prompted, set up the OAuth consent screen first (choose "External")
#   3. Create Credentials -> OAuth client ID -> Application type: Web application
#   4. Add your site under "Authorized JavaScript origins"
#      (https://speakport-h4k8.onrender.com and, for local testing, http://localhost:8000)
#   GOOGLE_CLIENT_ID=123456789-abc123.apps.googleusercontent.com

# ---- AI Roleplay + connected-speech breakdown (optional — Max plan tier only) ----
# One Gemini key powers two Max-only things: AI Roleplay (free-form spoken
# conversation) and the connected-speech breakdown inside Songs (No Rhythm
# -> Linking -> Reduced -> Fluency), which works on any line of English the
# learner types in. Leave unset and those two features tell learners it
# isn't turned on yet. Get a free key (no credit card needed) at
# https://aistudio.google.com/apikey
#   GEMINI_API_KEY=...
#   GEMINI_MODEL=gemini-3.1-flash-lite    (optional override — Google retires
#                                     model names often, so if you ever see a
#                                     404 "no longer available" error, check
#                                     https://ai.google.dev/gemini-api/docs/models
#                                     for the current cheapest Stable model)
#
# Songs itself needs NO API key or account of any kind -- the learner
# pastes a link to any real song on YouTube, the page embeds YouTube's own
# player (they hold the rights, not us), and practice lines are typed in
# by the learner, not fetched from any lyrics database.

# ---- Database (optional locally, required in production) ----
# Leave unset on your Mac — SpeakUp uses a local SQLite file automatically,
# nothing to install. Only set this in production (e.g. on Render, this is
# wired up for you automatically via render.yaml).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Payments (optional locally) ----
# Leave everything below unset and SpeakUp runs in DEMO MODE: the "Upgrade
# to Pro" button instantly grants Pro, so you can test everything without a
# real payment account.
#
# ZainCash (recommended if your business is based in Iraq — Paddle, Stripe,
# Lemon Squeezy, and Dodo all refuse to onboard sellers from Iraq, but
# ZainCash is Iraq's own mobile-wallet payment gateway). Get these after
# ZainCash approves your business: https://zaincash.iq/business/business-wallet-registration
#   ZAINCASH_CLIENT_ID=...
#   ZAINCASH_CLIENT_SECRET=...
#   ZAINCASH_ENV=test               (or "production" when you're ready to go live)
# ZainCash only settles in Iraqi Dinar (IQD). Set your price with:
#   PRO_PRICE_USD=4.99               (shown to users for reference only)
#   PRO_PRICE_IQD=6500                (what ZainCash actually charges)
#
# QiCard / "Pay with SuperQi" (a SECOND, separate Iraqi payment rail you can
# run alongside ZainCash — reaches customers who hold a Qi Card issued via
# Rafidain Bank or Rasheed Bank, which covers a large share of Iraq's banked
# population, including government employees and pensioners). Unlike
# ZainCash, QiCard doesn't publish self-serve sandbox credentials — request
# a Terminal ID + username/password from their merchant team first:
# https://qi.iq/en/merchants/online-payment-gateway or email qicard@qi.iq
#   QICARD_TERMINAL_ID=...
#   QICARD_USERNAME=...
#   QICARD_PASSWORD=...
#   QICARD_ENV=test                  (or "production" when you're ready to go live)
# Both ZainCash and QiCard can be configured at the same time — the paywall
# will show a "Pay with ZainCash" and a "Pay with Qi Card / SuperQi" button.
#
# Paddle (only usable if your business is based somewhere Paddle supports —
# see paddle.com/help/start/intro-to-paddle/which-countries-are-supported-by-paddle).
# Set all four to accept real money via Paddle instead:
#   PADDLE_API_KEY=...             (Developer Tools -> Authentication)
#   PADDLE_WEBHOOK_SECRET=...      (Developer Tools -> Notifications)
#   PADDLE_CLIENT_TOKEN=...        (Developer Tools -> Authentication, public)
#   PADDLE_PRICE_ID=...            (Catalog -> your $4.99/mo price)
#   PADDLE_ENV=sandbox             (or "production" when you're ready to go live)
# See README section 5 for full setup steps.
